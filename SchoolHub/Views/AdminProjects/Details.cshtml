@model SchoolHub.Models.Project
@{
	ViewData["Title"] = "Детали пректа";
}

<div class="container mt-5">
	<div class="card shadow">
		<div class="card-body">
			<h1 class="mb-3">@Model.Title</h1>
				<p class="mb-3">
					<span class="badge bg-primary">@Model.Category</span>
					<span class="badge bg-secondary">@Model.Status</span>
				</p>
			<p class="mb-1">
				<strong>Автор</strong> @Model.Author?.Name
			</p>
			<p class="mb-3">
				<strong>Дата создание</strong> @Model..CreatedAt.ToString("dd.MM.yyyy HH:mm")
			</p>
			<div class="d-flex gap-2">
				<a asp-controller="AdminProjects" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
					Редактировать
					</a>
			</div>
		</div>
	</div>
</div>